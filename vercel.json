{
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "backend/app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/app.py"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/frontend/dist/assets/$1"
        },
        {
            "src": "/manifest.json",
            "dest": "/frontend/dist/manifest.json"
        },
        {
            "src": "/vite.svg",
            "dest": "/frontend/dist/vite.svg"
        },
        {
            "src": "/favicon.ico",
            "dest": "/frontend/dist/favicon.ico"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/dist/index.html"
        }
    ]
}